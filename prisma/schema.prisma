// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String    @id @default(cuid())
  name      String?
  email     String?   @unique
  image     String?
  emailVerified DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]

  repos     Repo[]
  posts     GeneratedPost[]
  strategies ProjectStrategy[]
  settings  UserSettings?
  seenUrls  SeenUrl[]
  newsTweets NewsTweet[]
}

model UserSettings {
  id          String   @id @default(cuid())
  userId      String   @unique
  voiceMemory String?
  tone        String?
  newsSources       String?
  newsKeywords      String?
  newsTone          String?
  newsExclude       String?
  newsTasteProfile  String?
  newsAutoFetch     Boolean  @default(false)
  newsEmailEnabled  Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SeenUrl {
  id        String   @id @default(cuid())
  userId    String
  url       String
  seenAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, url])
  @@index([userId, seenAt])
}

model NewsTweet {
  id           String   @id @default(cuid())
  userId       String
  articleUrl   String
  articleTitle String
  tone         String
  tweet        String
  status       String   @default("pending") // pending | approved | rejected | posted
  postedAt     DateTime?
  tweetId      String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([articleUrl, createdAt])
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repo {
  id        String   @id @default(cuid())
  userId    String
  owner     String
  name      String
  fullName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  events    GitHubEvent[]
  posts     GeneratedPost[]
  strategies ProjectStrategy[]

  @@index([userId])
  @@unique([userId, fullName])
}

model GitHubEvent {
  id          String   @id @default(cuid())
  repoId      String
  type        String   // "commit" (MVP)
  externalId  String   // commit SHA
  title       String   // commit message subject
  url         String?
  authorLogin String?
  authoredAt  DateTime?
  payloadJson String   // serialized JSON (files changed etc)
  createdAt   DateTime @default(now())

  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([repoId, type, externalId])
  @@index([repoId, createdAt])
}

model GeneratedPost {
  id          String   @id @default(cuid())
  userId      String
  repoId      String?
  sourceType  String   // "commit"
  sourceId    String   // commit SHA
  style       String   // "progress" | "insight" | "build_in_public"
  content     String
  status      String   @default("draft") // draft | copied | posted
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo Repo? @relation(fields: [repoId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([repoId, createdAt])
  @@index([sourceType, sourceId])
}

model ProjectStrategy {
  id        String   @id @default(cuid())
  userId    String
  repoId    String
  content   String   // JSON array of JourneyPost objects
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  repo Repo @relation(fields: [repoId], references: [id], onDelete: Cascade)

  @@unique([userId, repoId])
  @@index([userId, repoId, createdAt])
}
